{deps, [
    {lager, ".*", {git, "https://github.com/basho/lager", {tag, "2.2.0"}}}
]}.

{erl_opts, [debug_info, {parse_transform, lager_transform}]}.

%% triq is only used to compile the property-based statem suite (test/smc_triq.erl),
%% so keep it out of the default build — consumers no longer pull it transitively.
{profiles, [
    {test, [{deps, [{triq, {git, "https://github.com/krestenkrab/triq", {branch, "master"}}}]}]}
]}.
